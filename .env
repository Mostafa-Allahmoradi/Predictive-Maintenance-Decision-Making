# =============================================================================
# Predictive Maintenance RL — Hyperparameter Configuration
# =============================================================================
# Edit values here to tune the project without touching source code.
# All values are loaded by pdm/config.py at import time.
# Real environment variables always take precedence over this file.
# =============================================================================

# ── Environment / reward shaping ─────────────────────────────────────────────
ENV_SCHEDULED_MAINTENANCE_COST=-20.0
ENV_SAFE_CYCLE_REWARD=1.0
ENV_CATASTROPHIC_FAILURE_PENALTY=-100.0
ENV_PROXIMITY_PENALTY_THRESHOLD=20
ENV_PROXIMITY_PENALTY_SCALE=2.0

# ── Economic costs (used by evaluation and sensitivity scripts) ───────────────
COST_MAINTENANCE_UNIT=20.0
COST_FAILURE_UNIT=100.0

# ── Data preprocessing ────────────────────────────────────────────────────────
DATA_SUBSET=FD001
DATA_WINDOW_SIZE=30

# ── Training pipeline ─────────────────────────────────────────────────────────
TRAIN_NUM_EPISODES=500
TRAIN_SEED=42
TRAIN_FIXED_INTERVAL=150

# ── Double DQN ────────────────────────────────────────────────────────────────
DDQN_GAMMA=0.99
DDQN_LEARNING_RATE=0.0003
DDQN_LR_END_FACTOR=0.05
DDQN_LR_DECAY_STEPS=50000
DDQN_EPSILON_START=1.0
DDQN_EPSILON_END=0.02
DDQN_EPSILON_DECAY=0.99995
DDQN_BATCH_SIZE=256
DDQN_BUFFER_CAPACITY=100000
DDQN_TAU=0.005
DDQN_HIDDEN_DIM=256
DDQN_MAX_GRAD_NORM=5.0

# ── Prioritised Experience Replay (PER) ───────────────────────────────────────
PER_ALPHA=0.6
PER_BETA_START=0.4
PER_BETA_END=1.0
PER_BETA_ANNEAL_STEPS=200000
PER_FAILURE_BOOST=5.0
PER_FAILURE_RUL_THRESHOLD=30

# ── Dyna-Q ────────────────────────────────────────────────────────────────────
DYNAQ_PLANNING_STEPS=100
DYNAQ_WORLD_MODEL_LR=0.0003

# ── Evaluation ────────────────────────────────────────────────────────────────
EVAL_FDR_THRESHOLD=50
EVAL_SEED=42
EVAL_FIXED_INTERVAL=150

# ── Sensitivity analysis ──────────────────────────────────────────────────────
# Comma-separated list of failure costs to sweep
SENS_FAILURE_COST_SWEEP=50,100,200,300,500,1000
SENS_SEED=42
SENS_FIXED_INTERVAL=150
